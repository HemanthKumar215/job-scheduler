{
  "name": "distributed-job-scheduler",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "prisma",
    "api",
    "worker",
    "frontend"
  ],
  "scripts": {
    "db:up": "docker compose up -d postgres redis",
    "db:migrate": "npm run migrate -w prisma",
    "db:seed": "npm run seed -w prisma",
    "build": "npm run build -w prisma && npm run build -w api && npm run build -w worker && npm run build -w frontend",
    "start:api": "npm run start -w api",
    "start:worker": "npm run start -w worker",
    "dev:api": "npm run dev -w api",
    "dev:worker": "npm run dev -w worker",
    "dev:frontend": "npm run dev -w frontend",
    "test": "vitest run --workspace=vitest.workspace.ts",
    "test:proofs": "vitest run --workspace=vitest.workspace.ts --project=proofs"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "dependencies": {
    "cron-parser": "^4.9.0"
  }
}
